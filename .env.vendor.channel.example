# Vendor Channel Configuration Template
# Copy this file to .env.<vendor>.<channel> (e.g., .env.bca.va, .env.bri.va, .env.mandiri.va)
# All variables use VENDOR_ prefix for vendor-specific settings

# ============================================================
# Vendor Identification
# ============================================================
# VENDOR_NAME=<vendor>       # e.g., bca, bri, mandiri
# VENDOR_CHANNEL=<channel>   # e.g., va, qris, transfer

# ============================================================
# Authentication
# ============================================================
VENDOR_CLIENT_ID=
VENDOR_CLIENT_SECRET=
VENDOR_PRIVATE_KEY_PATH=
VENDOR_PUBLIC_KEY_PATH=

# ============================================================
# Base URL (per environment)
# ============================================================
# Sandbox
VENDOR_BASE_URL=https://sandbox.<vendor>.co.id
# Production (uncomment for production)
# VENDOR_BASE_URL=https://www.<vendor>.co.id

# ============================================================
# Token Endpoint
# ============================================================
VENDOR_TOKEN_ENDPOINT=/openapi/v1.0/access-token/b2b

# ============================================================
# API Endpoints (ENDPOINT_NAME=url format)
# Add/remove endpoints based on vendor API
# ============================================================
VENDOR_ENDPOINT_INQUIRY=/openapi/v1.0/transfer-va/inquiry
VENDOR_ENDPOINT_STATUS=/openapi/v1.0/transfer-va/status
VENDOR_ENDPOINT_PAYMENT=/openapi/v1.0/transfer-va/payment

# ============================================================
# Channel Configuration
# ============================================================
VENDOR_CHANNEL_ID=
VENDOR_PARTNER_ID=
VENDOR_ORIGIN=yourdomain.com

# ============================================================
# Request Configuration
# ============================================================
VENDOR_REQUEST_TIMEOUT=30
VENDOR_SIGNATURE_ALGORITHM=HMAC-SHA512

# ============================================================
# SNAP Headers (comma-separated list of required headers)
# Customize based on vendor requirements
# ============================================================
VENDOR_REQUIRED_HEADERS=X-TIMESTAMP,X-CLIENT-KEY,X-SIGNATURE,CHANNEL-ID,X-PARTNER-ID,X-EXTERNAL-ID

# ============================================================
# Response Code Format
# ============================================================
VENDOR_RESPONSE_CODE_FORMAT=AAABBCC

# ============================================================
# Defaults
# ============================================================
VENDOR_DEFAULT_SUB_COMPANY=00000
VENDOR_DEFAULT_CHANNEL_CODE=6011

# ============================================================
# Logging
# ============================================================
VENDOR_DEBUG_LOGGING=false
VENDOR_CORRELATION_HEADER=X-Correlation-ID
