# Global Configuration for Payment Gateway
# Copy this file to .env and update values

# ============================================================
# Server Configuration
# ============================================================
PORT=8080

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=payment_gateway
DB_SSLMODE=disable

# ============================================================
# Redis Configuration
# ============================================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
# Timeout for the initial Redis PING on startup
REDIS_CONNECT_TIMEOUT_SECONDS=1

# ============================================================
# Idempotency Middleware Configuration
# ============================================================
# How long a concurrent duplicate request is held off while the original
# (same Idempotency-Key) is still being processed.
IDEMPOTENCY_LOCK_TTL_SECONDS=30
# How long a completed response is replayed for a repeated Idempotency-Key.
IDEMPOTENCY_CACHE_TTL_SECONDS=86400

# ============================================================
# Asynq Queue Configuration
# ============================================================
ASYNQ_REDIS_ADDR=localhost:6379
ASYNQ_REDIS_PASSWORD=
ASYNQ_REDIS_DB=1
ASYNQ_CONCURRENCY=10

# ============================================================
# Telemetry Configuration (OpenTelemetry)
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=

# ============================================================
# Configuration Directory
# ============================================================
CONFIG_DIR=.

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json


# ============================================================
# Admin API Key (for /admin endpoints)
# ============================================================
ADMIN_API_KEY=changeme